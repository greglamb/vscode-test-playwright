{
  "name": "@greglamb/vscode-test-playwright",
  "version": "0.0.1-beta9",
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "watch": "tsc --watch",
    "test": "playwright test"
  },
  "keywords": [
    "vscode",
    "playwright",
    "testing",
    "extension"
  ],
  "author": "Rui Figueira (https://github.com/ruifigueira)",
  "contributors": [
    "Greg Lamb <email@greglamb.dev> (https://github.com/greglamb)"
  ],
  "license": "Apache-2.0",
  "description": "Run VS Code extension tests with Playwright: drive the workbench UI and evaluate code inside the extension host from the same test.",
  "repository": {
    "type": "git",
    "url": "https://github.com/greglamb/vscode-test-playwright.git"
  },
  "homepage": "https://github.com/greglamb/vscode-test-playwright#readme",
  "bugs": {
    "url": "https://github.com/greglamb/vscode-test-playwright/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.29",
    "@types/vscode": "^1.100.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.52.0"
  },
  "dependencies": {
    "@vscode/test-electron": "^2.5.2",
    "ws": "^8.18.2"
  }
}
